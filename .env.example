# Copy to .env and fill in real values (never commit .env)

AWS_REGION=eu-north-1
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/YourSageMakerRole
S3_BUCKET_NAME=your-s3-bucket-name

# 本地开发：使用 IAM 用户或 STS 临时凭证（与 aws configure / export 一致）
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# 使用 aws sts assume-role 等产生临时密钥时必填
# AWS_SESSION_TOKEN=your-session-token

# Optional: override default PyTorch training image
# TRAINING_IMAGE_URI=763104351884.dkr.ecr.eu-north-1.amazonaws.com/pytorch-training:2.0.0-gpu-py310-cu118-ubuntu20.04-sagemaker

# Optional: presigned PUT expiry in seconds (default 3600)
# PRESIGNED_PUT_EXPIRES=3600
