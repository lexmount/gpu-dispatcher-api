# 复制为仓库根目录 .env
# 注意：本服务 EC2 区域在 main.py 中写死为 eu-north-1，不受 AWS_REGION 影响

# IAM 用户或角色会话（与 aws configure / 环境变量一致）
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=  # 临时凭证时填写

# 可选：覆盖默认 AMI（须为 eu-north-1 可用镜像）
# DEEP_LEARNING_AMI_ID=ami-080254318c2d8932f
